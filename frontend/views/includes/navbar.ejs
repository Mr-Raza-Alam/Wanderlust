<style>
  .srchBar {
    width: 20rem;
    border: 1.5px solid #dddddd;
    border-radius: 2rem;
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
    transition: all 0.25s ease;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
  }
  .srchBar:focus {
    border-color: #222222;
    box-shadow: 0 2px 8px rgba(0,0,0,0.14);
    outline: none;
  }
  .srchBtn {
    background: linear-gradient(135deg, #FF385C, #E31C5F);
    color: #fff;
    border: none;
    border-radius: 2rem;
    font-weight: 600;
    font-size: 0.9rem;
    padding: 0.5rem 1.2rem;
    transition: all 0.25s ease;
    box-shadow: 0 2px 8px rgba(255,56,92,0.3);
  }
  .srchBtn:hover {
    background: linear-gradient(135deg, #E31C5F, #c8175a);
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(255,56,92,0.4);
    color: #fff;
  }
  .srchBtn i { display: inline; margin-right: .3rem; }
</style>
<!-- Navbar -->
<nav class="navbar navbar-expand-md border-bottom sticky-top"
  style="background-color: #fff; border-bottom: 1px solid #ebebeb !important; box-shadow: none;">
  <div class="container-fluid">
    <a class="navbar-brand d-flex align-items-center" href="/" style="gap: 0.4rem; text-decoration: none;">
      <i class="fa-solid fa-compass" style="color: #FF385C; font-size: 1.8rem;"></i>
      <span style="font-family: 'Inter', sans-serif; font-weight: 800; color: #FF385C; font-size: 1.3rem; letter-spacing: -0.5px;">WanderLust</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings" style="font-weight: 500; color: #222222;">
          <i class="fa-solid fa-globe" style="color: #FF385C; margin-right: 0.3rem;"></i>Explore
        </a>
      </div>
      <div class="navbar-nav ms-auto searchBox">
        <form class="d-flex" role="search" action="/listings/search" method="get">
          <input name="searchLocation" class="form-control me-2 srchBar" type="search"
            placeholder="Search Destinations..." aria-label="Search" autocomplete="on" />
          <button class="btn srchBtn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new" style="font-weight: 500; color: #222222;">
          <i class="fa-solid fa-plus" style="color: #FF385C; margin-right: 0.3rem;"></i>List Property
        </a>
        <% if(typeof currUser==="undefined" || !currUser){ %>
          <a class="nav-link" href="/listings/signup"
            style="font-weight: 600; color: #FF385C !important;">Signup</a>
          <a class="nav-link" href="/listings/login" style="font-weight: 600; color: #222222;"><b>Login</b></a>
        <%}else{ %>
          <a class="nav-link" href="/listings/logout"
            style="font-weight: 600; color: #717171 !important;">
            <i class="fa-solid fa-right-from-bracket" style="margin-right: 0.3rem;"></i>Logout
          </a>
        <% } %>
      </div>
    </div>
  </div>
</nav>