<style>
  .srchBar {
    width: 18rem;
    border: 2px solid #d1d5db;
    border-radius: 1.4rem;
    padding: .3rem 3rem .3rem 1.2rem;
    font-size: 1rem;
    transition: all 0.3s ease;
  }

  .srchBar:focus {
    border-color: #0d9f6e;
    box-shadow: 0 0 0 3px rgba(13, 159, 110, 0.12);
    outline: none;
  }

  .srchBtn {
    width: 8rem;
    background-color: #0d9f6e;
    color: #fff;
    border: none;
    border-radius: 1.4rem;
    font-weight: 600;
    transition: all 0.3s ease;
  }

  .srchBtn:hover {
    background-color: #046c4e;
    color: #fff;
    transform: translateY(-1px);
    box-shadow: 0 4px 12px rgba(13, 159, 110, 0.3);
  }

  .srchBtn i {
    display: inline;
    margin-right: .3rem;
  }
</style>
<!-- Template for navbar using bootstrap -->
<nav class="navbar navbar-expand-md border-bottom sticky-top"
  style="background-color: #fff; box-shadow: 0 2px 12px rgba(0,0,0,0.06);">
  <div class="container-fluid">
    <a class="navbar-brand d-flex align-items-center" href="/" style="gap: 0.4rem;">
      <i class="fa-solid fa-compass" style="color: #0d9f6e; font-size: 1.8rem;"></i>
      <span
        style="font-family: 'Inter', sans-serif; font-weight: 700; color: #014737; font-size: 1.2rem;">WanderLust</span>
    </a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNavAltMarkup"
      aria-controls="navbarNavAltMarkup" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarNavAltMarkup">
      <div class="navbar-nav">
        <a class="nav-link" href="/listings" style="font-weight: 500;"><i class="fa-solid fa-globe"
            style="color: #0d9f6e; margin-right: 0.3rem;"></i>Explore</a>
      </div>
      <div class="navbar-nav ms-auto searchBox">
        <form class="d-flex" role="search" action="/listings/search" method="post">
          <input name="searchLocation" class="form-control me-2 srchBar" type="search"
            placeholder="Search Destinations..." aria-label="Search" autocomplete="on" />
          <button class="btn srchBtn" type="submit"><i class="fa-solid fa-magnifying-glass"></i>Search</button>
        </form>
      </div>
      <div class="navbar-nav ms-auto">
        <a class="nav-link" href="/listings/new" style="font-weight: 500;"><i class="fa-solid fa-plus"
            style="color: #0d9f6e; margin-right: 0.3rem;"></i>List Property</a>
        <% if(typeof currUser==="undefined" || !currUser){ %>
          <a class="nav-link" href="/listings/signup" style="font-weight: 600; color: #0d9f6e !important;">Signup</a>
          <a class="nav-link" href="/listings/login"><b>Login</b></a>
          <%}else{ %>
            <a class="nav-link" href="/listings/logout" style="font-weight: 600; color: #dc2626 !important;"><i
                class="fa-solid fa-right-from-bracket" style="margin-right: 0.3rem;"></i>Logout</a>
            <% } %>
      </div>
    </div>
  </div>
</nav>