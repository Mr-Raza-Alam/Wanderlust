<!-- Template For display all listing place -->
<% layout("/layouts/boilierPlate") -%>
<style>
  #filters {
    display: flex;
    flex-wrap: nowrap;
    overflow-x: auto;
    gap: 0;
    padding: 1rem 0 0.5rem;
    border-bottom: 1px solid #ebebeb;
    scrollbar-width: none;
    align-items: center;
  }
  #filters::-webkit-scrollbar { display: none; }
  .filter {
    text-align: center;
    padding: 0 1.2rem;
    opacity: 0.6;
    flex: 0 0 auto;
    border-bottom: 2px solid transparent;
    transition: all 0.2s ease;
    cursor: not-allowed;
  }
  .filter:hover {
    opacity: 1;
    border-bottom: 2px solid #222222;
  }
  .filter div i { font-size: 1.4rem; color: #222222; }
  .filter p   { font-size: 0.72rem; color: #222222; margin: 0.3rem 0 0; font-weight: 500; }
  .tax-info   { display: none; }
  .tax-toggle {
    display: flex;
    align-items: center;
    height: 3rem;
    padding: 0 1rem;
    border: 1px solid #dddddd;
    border-radius: 0.75rem;
    margin-left: auto;
    flex-shrink: 0;
    gap: 0.5rem;
    font-size: 0.82rem;
    white-space: nowrap;
    color: #222222;
  }
</style>

<div id="filters" title="Category filters coming soon!">
  <div class="filter"><div><i class="fa-solid fa-fire"></i></div><p>Trending</p></div>
  <div class="filter"><div><i class="fa-solid fa-bed"></i></div><p>Rooms</p></div>
  <div class="filter"><div><i class="fa-solid fa-mountain-city"></i></div><p>Iconic Cities</p></div>
  <div class="filter"><div><i class="fa-solid fa-person-swimming"></i></div><p>Amazing Pools</p></div>
  <div class="filter"><div><i class="fa-solid fa-umbrella-beach"></i></div><p>Beach</p></div>
  <div class="filter"><div><i class="fa-solid fa-sailboat"></i></div><p>Boats</p></div>
  <div class="filter"><div><i class="fa-solid fa-hill-avalanche"></i></div><p>Arctic</p></div>
  <div class="filter"><div><i class="fa-brands fa-fort-awesome"></i></div><p>Castles</p></div>
  <div class="filter"><div><i class="fa-solid fa-tent-arrow-left-right"></i></div><p>Camping</p></div>
  <div class="filter"><div><i class="fa-solid fa-cow"></i></div><p>Farms</p></div>
  <div class="filter"><div><i class="fa-solid fa-igloo"></i></div><p>Domes</p></div>
  <div class="filter"><div><i class="fa-solid fa-utensils"></i></div><p>Breakfast</p></div>
  <div class="filter"><div><i class="fa-solid fa-person-skiing"></i></div><p>Skiing</p></div>
  <div class="tax-toggle">
    <div class="form-check-reverse form-switch">
      <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
      <label class="form-check-label" for="switchCheckDefault">Display total after taxes</label>
    </div>
  </div>
</div>

<div class="row row-cols-xl-4 row-cols-lg-3 row-cols-md-2 row-cols-sm-1 g-4 mt-1 px-2">
  <% for(let list of allList){ %>
    <div class="col">
      <div class="listing-card">
        <a href="/listings/<%= list._id %>" class="listing-link">
          <div style="overflow: hidden; border-radius: 0.75rem;">
            <img src="<%= list.image.url %>" class="card-img-top" alt="listing_image">
          </div>
          <div class="card-body">
            <h5 class="card-title"><%= list.title %></h5>
            <p class="card-text" style="color: #717171; font-size: 0.875rem;">
              <span style="color: #222; font-weight: 600;">&#8377;<%= list.price.toLocaleString("en-IN")%></span> / night
              <i class="tax-info">&nbsp;&nbsp;+18% GST</i>
            </p>
          </div>
        </a>
      </div>
    </div>
  <% } %>
</div>

<script>
  let taxSwitch = document.getElementById("switchCheckDefault");
  taxSwitch.addEventListener("click", () => {
    let taxInfo = document.getElementsByClassName("tax-info");
    for (let info of taxInfo) {
      info.style.display = (info.style.display !== "inline") ? "inline" : "none";
    }
  });
</script>