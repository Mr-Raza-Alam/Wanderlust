<!-- Template for edit form -->
<% layout("/layouts/boilierPlate") -%>

<div class="form-page-wrapper">
  <div class="form-page-card">
    <!-- Header -->
    <div class="form-page-header">
      <div class="form-page-icon">
        <i class="fa-solid fa-pen-to-square"></i>
      </div>
      <h2 class="form-page-title">Edit Listing</h2>
      <p class="form-page-subtitle">Update the details for your property</p>
    </div>

    <!-- Form -->
    <form method="post" action="/listings/<%= editing._id%>?_method=PUT"
      class="form-page-form needs-validation" novalidate enctype="multipart/form-data">

      <!-- Title -->
      <div class="form-page-field">
        <label for="tit" class="form-page-label">
          <i class="fa-solid fa-heading"></i> Title
        </label>
        <input type="text" id="tit" name="listing[title]" value="<%= editing.title %>"
          class="form-page-input" placeholder="e.g. Cozy Mountain Cabin" required>
        <div class="invalid-feedback">
          <i class="fa-solid fa-circle-exclamation"></i> Title is required
        </div>
      </div>

      <!-- Current Image Preview -->
      <div class="form-page-field">
        <label class="form-page-label">
          <i class="fa-solid fa-image"></i> Current Image
        </label>
        <img src="<%= originalImageUrl %>" alt="current listing image"
          style="width: 100%; height: 200px; object-fit: cover; border-radius: 0.625rem; border: 1.5px solid #ebebeb;">
      </div>

      <!-- New Image Upload -->
      <div class="form-page-field">
        <label for="img" class="form-page-label">
          <i class="fa-solid fa-camera"></i> Replace Image
          <span class="form-page-hint">(optional — leave blank to keep current)</span>
        </label>
        <div class="form-page-file-wrap">
          <input type="file" id="img" name="listing[image]" class="form-page-file" accept=".jpg,.jpeg,.png">
          <div class="form-page-file-label">
            <i class="fa-solid fa-cloud-arrow-up"></i>
            <span>Choose a new photo</span>
          </div>
        </div>
      </div>

      <!-- Description -->
      <div class="form-page-field">
        <label for="desc" class="form-page-label">
          <i class="fa-solid fa-align-left"></i> Description
        </label>
        <textarea name="listing[description]" id="desc" rows="4"
          class="form-page-input form-page-textarea" required><%= editing.description %></textarea>
        <div class="invalid-feedback">
          <i class="fa-solid fa-circle-exclamation"></i> Description is required
        </div>
      </div>

      <!-- Price & Country -->
      <div class="form-page-row">
        <div class="form-page-field form-page-field-half">
          <label for="price" class="form-page-label">
            <i class="fa-solid fa-indian-rupee-sign"></i> Price
            <span class="form-page-hint">(per night)</span>
          </label>
          <input type="number" id="price" name="listing[price]" value="<%= editing.price %>"
            class="form-page-input" min="0" required>
          <div class="invalid-feedback">
            <i class="fa-solid fa-circle-exclamation"></i> Price is required
          </div>
        </div>
        <div class="form-page-field form-page-field-half">
          <label for="count" class="form-page-label">
            <i class="fa-solid fa-flag"></i> Country
          </label>
          <input type="text" id="count" name="listing[country]" value="<%= editing.country %>"
            class="form-page-input" required>
          <div class="invalid-feedback">
            <i class="fa-solid fa-circle-exclamation"></i> Country is required
          </div>
        </div>
      </div>

      <!-- Location -->
      <div class="form-page-field">
        <label for="locate" class="form-page-label">
          <i class="fa-solid fa-location-dot"></i> Location
        </label>
        <input type="text" name="listing[location]" value="<%= editing.location %>"
          class="form-page-input" id="locate" required>
        <div class="invalid-feedback">
          <i class="fa-solid fa-circle-exclamation"></i> Location is required
        </div>
      </div>

      <!-- Action Buttons -->
      <div class="form-page-actions">
        <a href="/listings/<%= editing._id %>/editBack" class="form-page-btn-back">
          <i class="fa-solid fa-arrow-left"></i> Back
        </a>
        <button type="submit" id="editBtn" class="auth-btn">
          <i class="fa-solid fa-floppy-disk"></i> Save Changes
        </button>
      </div>

    </form>
  </div>
</div>
