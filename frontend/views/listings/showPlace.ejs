<!-- template for individual listing show page -->
<% layout("/layouts/boilierPlate") -%>
<link href="https://api.mapbox.com/mapbox-gl-js/v3.12.0/mapbox-gl.css" rel="stylesheet">
<script src="https://api.mapbox.com/mapbox-gl-js/v3.12.0/mapbox-gl.js"></script>
<script>
  const mapToken = "<%= process.env.MAP_TOKEN%>";
</script>

<div class="container-fluid px-4 px-md-5 py-4" style="max-width: 1000px; margin: 0 auto;">

  <!-- Title & Owner -->
  <h2 style="font-weight: 700; font-size: 1.75rem; color: #222; margin-bottom: 0.3rem;"><%= showList.title %></h2>
  <p style="color: #717171; font-size: 0.9rem; margin-bottom: 1.5rem;">
    <i class="fa-solid fa-location-dot" style="color: #FF385C;"></i>
    <%= showList.location %>, <%= showList.country %> &nbsp;·&nbsp;
    Hosted by <strong><%= showList.owner.username %></strong>
  </p>

  <!-- Main Image -->
  <img src="<%= showList.image.url %>" class="show-img w-100 mb-4" alt="listing image">

  <!-- Details Row -->
  <div class="row g-4">

    <!-- Left: Description + Reviews -->
    <div class="col-md-7">
      <div style="border-bottom: 1px solid #ebebeb; padding-bottom: 1.5rem; margin-bottom: 1.5rem;">
        <h5 style="font-weight: 700; margin-bottom: 0.5rem;">About this place</h5>
        <p style="color: #444; line-height: 1.7;"><%= showList.description %></p>
      </div>

      <!-- Owner Actions -->
      <% if(currUser && currUser._id.equals(showList.owner._id)){ %>
      <div class="d-flex gap-3 mb-4">
        <a href="/listings/<%= showList._id %>/edit" class="btn btn-primary">
          <i class="fa-solid fa-pen"></i> Edit Listing
        </a>
        <form method="post" action="/listings/<%= showList._id %>?_method=DELETE">
          <button id="delBtn" type="submit" class="btn btn-danger">
            <i class="fa-solid fa-trash"></i> Delete
          </button>
        </form>
      </div>
      <%}%>

      <!-- Review Form -->
      <% if(currUser){ %>
      <div style="border-top: 1px solid #ebebeb; padding-top: 1.5rem; margin-bottom: 1.5rem;">
        <h5 style="font-weight: 700; margin-bottom: 1rem;">Leave a Review</h5>
        <form action="/listings/<%= showList.id %>/reviews" method="post" novalidate class="needs-validation">
          <div class="mb-3">
            <label for="rating" class="form-label fw-semibold">Your Rating</label>
            <fieldset class="starability-heart">
              <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
              <input type="radio" id="first-rate1" name="review[rating]" value="1" />
              <label for="first-rate1" title="Terrible">1 star</label>
              <input type="radio" id="first-rate2" name="review[rating]" value="2" />
              <label for="first-rate2" title="Not good">2 stars</label>
              <input type="radio" id="first-rate3" name="review[rating]" value="3" />
              <label for="first-rate3" title="Average">3 stars</label>
              <input type="radio" id="first-rate4" name="review[rating]" value="4" />
              <label for="first-rate4" title="Very good">4 stars</label>
              <input type="radio" id="first-rate5" name="review[rating]" value="5" />
              <label for="first-rate5" title="Amazing">5 stars</label>
            </fieldset>
          </div>
          <div class="mb-3">
            <label for="comment" class="form-label fw-semibold">Your Comment</label>
            <textarea name="review[comment]" id="comment" rows="4" class="form-control" required
              placeholder="Tell others what you loved about this place..."></textarea>
            <div class="invalid-feedback">Please add a comment before submitting.</div>
          </div>
          <button class="btn btn-primary" type="submit">
            <i class="fa-solid fa-paper-plane"></i> Submit Review
          </button>
        </form>
      </div>
      <% } %>

      <!-- All Reviews -->
      <% if(showList.reviews.length > 0){ %>
      <div style="border-top: 1px solid #ebebeb; padding-top: 1.5rem;">
        <h5 style="font-weight: 700; margin-bottom: 1.25rem;">
          <i class="fa-solid fa-star" style="color: #FF385C;"></i>
          <%= showList.reviews.length %> Review<%= showList.reviews.length > 1 ? 's' : '' %>
        </h5>
        <div class="row g-3">
          <% for(let review of showList.reviews){ %>
          <div class="col-md-6">
            <div style="background: #f7f7f7; border-radius: 0.75rem; padding: 1rem 1.25rem;">
              <div class="d-flex justify-content-between align-items-center mb-1">
                <strong style="color: #222; font-size: 0.95rem;">@<%= review.author.username%></strong>
              </div>
              <p class="starability-result" data-rating="<%= review.rating %>" style="margin-bottom: 0.5rem;"></p>
              <p style="color: #444; font-size: 0.875rem; margin: 0;"><%= review.comment %></p>
              <% if(currUser && currUser._id.equals(review.author._id)){ %>
              <form class="mt-2" action="/listings/<%= showList._id%>/reviews/<%= review._id%>?_method=DELETE" method="post">
                <button class="btn btn-sm btn-danger" style="font-size: 0.78rem; padding: 0.2rem 0.6rem;">
                  <i class="fa-solid fa-trash"></i> Delete
                </button>
              </form>
              <% } %>
            </div>
          </div>
          <% } %>
        </div>
      </div>
      <% } %>
    </div>

    <!-- Right: Price Card + Map -->
    <div class="col-md-5">
      <!-- Price Card -->
      <div style="border: 1.5px solid #ebebeb; border-radius: 0.75rem; padding: 1.5rem; box-shadow: 0 4px 20px rgba(0,0,0,0.08); position: sticky; top: 6rem;">
        <p style="font-size: 1.4rem; font-weight: 700; color: #222; margin-bottom: 0.25rem;">
          &#8377;<%= showList.price.toLocaleString("en-IN")%>
          <span style="font-size: 1rem; font-weight: 400; color: #717171;">/ night</span>
        </p>
        <p style="color: #717171; font-size: 0.875rem; margin-bottom: 1.25rem;">
          <i class="fa-solid fa-location-dot" style="color: #FF385C;"></i>
          <%= showList.location %>, <%= showList.country %>
        </p>
        <a href="/listings" class="btn btn-primary w-100">
          <i class="fa-solid fa-arrow-left"></i> Back to Listings
        </a>
      </div>
    </div>
  </div>

  <!-- Map -->
  <div class="mt-4">
    <h5 style="font-weight: 700; margin-bottom: 1rem;">Where you'll be</h5>
    <div id="map" data-coordinates='<%= JSON.stringify({geometry: showList.geometry, title: showList.title}) %>'></div>
  </div>

</div>

<script src="/JS/map.js"></script>