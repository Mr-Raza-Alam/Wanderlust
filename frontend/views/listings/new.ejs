    <!-- template for new creating form for user input -->
<!-- now i am going to include boilerplate code of ejs-Mate -->
<% layout("/layouts/boilierPlate") -%>

  <div class="form-page-wrapper">
    <div class="form-page-card">
      <!-- Header -->
      <div class="form-page-header">
        <div class="form-page-icon">
          <i class="fa-solid fa-house-chimney-crack"></i>
        </div>
        <h2 class="form-page-title">List Your Property</h2>
        <p class="form-page-subtitle">Share your space with travelers around the world</p>
      </div>

      <!-- Form -->
      <form method="post" action="/listings" novalidate class="form-page-form needs-validation"
        enctype="multipart/form-data">

        <!-- Title -->
        <div class="form-page-field">
          <label for="tit" class="form-page-label">
            <i class="fa-solid fa-heading"></i> Title
          </label>
          <input type="text" name="listing[title]" class="form-page-input" id="tit"
            placeholder="e.g. Cozy Mountain Cabin with Lake View" required />
          <div class="invalid-feedback">
            <i class="fa-solid fa-circle-exclamation"></i> Please add a catchy title for your listing
          </div>
        </div>

        <!-- Description -->
        <div class="form-page-field">
          <label for="desc" class="form-page-label">
            <i class="fa-solid fa-align-left"></i> Description
          </label>
          <textarea name="listing[description]" id="desc" rows="4" class="form-page-input form-page-textarea"
            placeholder="Describe your property — amenities, nearby attractions, special features..."
            required></textarea>
          <div class="invalid-feedback">
            <i class="fa-solid fa-circle-exclamation"></i> A description helps travelers know what to expect
          </div>
        </div>

        <!-- Image Upload -->
        <div class="form-page-field">
          <label for="image" class="form-page-label">
            <i class="fa-solid fa-camera"></i> Upload Image
            <span class="form-page-hint">(Max 1MB, JPEG/PNG)</span>
          </label>
          <div class="form-page-file-wrap">
            <input type="file" id="image" name="listing[image]" class="form-page-file" accept=".jpg,.jpeg,.png" required>
            <div class="form-page-file-label">
              <i class="fa-solid fa-cloud-arrow-up"></i>
              <span>Choose a photo of your property</span>
            </div>
          </div>
          <div class="valid-feedback">
            <i class="fa-solid fa-circle-check"></i> Image uploaded successfully!
          </div>
          <div class="invalid-feedback">
            <i class="fa-solid fa-circle-exclamation"></i> Please upload an image (max 1MB, JPEG format)
          </div>
        </div>

        <!-- Price & Country Row -->
        <div class="form-page-row">
          <div class="form-page-field form-page-field-half">
            <label for="price" class="form-page-label">
              <i class="fa-solid fa-indian-rupee-sign"></i> Price
              <span class="form-page-hint">(per night)</span>
            </label>
            <input type="number" name="listing[price]" class="form-page-input" id="price" min="0" placeholder="1500" required>
            <div class="invalid-feedback">
              <i class="fa-solid fa-circle-exclamation"></i> Price is required
            </div>
          </div>

          <div class="form-page-field form-page-field-half">
            <label for="count" class="form-page-label">
              <i class="fa-solid fa-flag"></i> Country
            </label>
            <input type="text" id="count" name="listing[country]" class="form-page-input" placeholder="India" required>
            <div class="invalid-feedback">
              <i class="fa-solid fa-circle-exclamation"></i> Which country is your property in?
            </div>
          </div>
        </div>

        <!-- Location -->
        <div class="form-page-field">
          <label for="locate" class="form-page-label">
            <i class="fa-solid fa-location-dot"></i> Location
          </label>
          <input type="text" class="form-page-input" name="listing[location]" id="locate"
            placeholder="e.g. Manali, Himachal Pradesh" required>
          <div class="invalid-feedback">
            <i class="fa-solid fa-circle-exclamation"></i> Please mention your property's location
          </div>
        </div>

        <!-- Terms Checkbox -->
        <div class="form-page-check">
          <input class="form-page-checkbox" type="checkbox" value="" id="invalidCheck" required>
          <label class="form-page-check-label" for="invalidCheck">
            I agree to the <a href="#" class="auth-link">Terms & Conditions</a>
          </label>
          <div class="invalid-feedback">
            <i class="fa-solid fa-circle-exclamation"></i> You must agree before submitting
          </div>
        </div>

        <!-- Action Buttons -->
        <div class="form-page-actions">
          <a href="/listings/newBack" class="form-page-btn-back">
            <i class="fa-solid fa-arrow-left"></i> Back
          </a>
          <button type="submit" class="auth-btn">
            <i class="fa-solid fa-plus"></i> Publish Listing
          </button>
        </div>

      </form>
    </div>
  </div>